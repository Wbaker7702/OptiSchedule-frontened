datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Store {
  id          Int       @id @default(autoincrement())
  storeNumber String    @unique
  state       String
  city        String
  employees   Employee[]
  shifts      Shift[]
  createdAt   DateTime  @default(now())
}

model Employee {
  id        Int      @id @default(autoincrement())
  firstName String
  birthdate DateTime
  isMinor   Boolean
  store     Store    @relation(fields: [storeId], references: [id])
  storeId   Int
  shifts    Shift[]
  createdAt DateTime @default(now())
}

model Shift {
  id         Int      @id @default(autoincrement())
  startTime  DateTime
  endTime    DateTime
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int
  store      Store    @relation(fields: [storeId], references: [id])
  storeId    Int
  createdAt  DateTime @default(now())
}

model MetricEvent {
  id        Int      @id @default(autoincrement())
  eventType String
  storeId   String
  createdAt DateTime @default(now())
}
